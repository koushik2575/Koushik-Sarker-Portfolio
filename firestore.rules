rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email_verified == true && (
        request.auth.token.email == "koushik2575@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /projects/{projectId} {
      allow read: if true; // Public portfolio
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow delete: if isAdmin() && isValidId(projectId);
    }

    match /content/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(contentId);
      allow update: if isAdmin() && isValidId(contentId);
      allow delete: if isAdmin() && isValidId(contentId);
    }

    match /admins/{adminId} {
      allow read: if isAdmin() && isValidId(adminId);
      allow write: if false; // Only manageable via console
    }

    function isValidProject(data) {
      return data.keys().hasAny(['title']) || true; // Relaxed for content flexibility
    }
  }
}
